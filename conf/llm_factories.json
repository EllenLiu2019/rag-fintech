{
    "chat_models": {
        "qa_reasoner": {
            "provider": "DeepSeek",
            "model_name": "deepseek-reasoner",
            "max_tokens": 128000,
            "description": "Deep reasoning model for complex QA tasks"
        },
        "qa_lite": {
            "provider": "DeepSeek",
            "model_name": "deepseek-chat",
            "max_tokens": 128000,
            "description": "Fast chat model for general QA"
        },
        "query_lite": {
            "provider": "Google",
            "model_name": "gemini-2.5-flash-lite",
            "max_tokens": 1048576,
            "description": "Lightweight model for query rewriting"
        },
        "query_reasoner": {
            "provider": "Google",
            "model_name": "gemini-2.5-flash",
            "max_tokens": 1048576,
            "description": "Powerful model for complex query understanding"
        }
    },
    "embedding_models": {
        "dense": {
            "provider": "Voyage",
            "model_name": "voyage-3.5-lite",
            "max_tokens": 32000,
            "dimensions": 1024,
            "description": "Dense embedding model for semantic search"
        },
        "sparse": {
            "provider": "BAAI",
            "model_name": "bge-m3",
            "max_tokens": 8192,
            "description": "Sparse embedding model for keyword matching"
        }
    },
    "reranker_models": {
        "qwen": {
            "provider": "QWen",
            "model_name": "gte-rerank-v2",
            "description": "Alibaba DashScope reranker API"
        },
        "default": {
            "provider": "Jina",
            "model_name": "jina-reranker-v3",
            "base_url": "https://api.jina.ai/v1/rerank",
            "description": "Jina AI reranker, based on Qwen3-0.6B"
        },
        "dev": {
            "provider": "FlagEmbedding",
            "model_name": "BAAI/bge-reranker-v2-m3",
            "description": "Development reranker (in-process)"
        },
        "prod": {
            "provider": "TEI",
            "model_name": "BAAI/bge-reranker-v2-m3",
            "base_url": "http://127.0.0.1:8080",
            "description": "Production reranker via TEI service"
        }
    }
}
