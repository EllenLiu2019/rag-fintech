{
    "fields": {
        "id": {"data_type": "varchar", "is_primary": true, "max_length": 100},
        "doc_id": {"data_type": "varchar", "max_length": 100},
        "file_name": {"data_type": "varchar", "max_length": 100},
        "page_number": {"data_type": "INT8", "default": 0},
        "prev_chunk": {"data_type": "varchar", "max_length": 100, "nullable": true, "default": "N/A"},
        "next_chunk": {"data_type": "varchar", "max_length": 100, "nullable": true, "default": "N/A"},
        "kb_id": {"data_type": "varchar", "max_length": 100},
        "dense_vector": {"data_type": "float_vector", "dim": 1024},
        "sparse_vector": {"data_type": "sparse_float_vector"},
        "text": {"data_type": "varchar", "max_length": 65535, "enable_analyzer": false},
        "business_data": {"data_type": "json", "nullable": true},
        "upload_time": {"data_type": "TIMESTAMPTZ", "nullable": true}
    },
    "indexes": {
        "dense_vector": {
            "index_name": "dense_vector_index", 
            "index_type": "FLAT", 
            "metric_type": "COSINE"
        },
        "sparse_vector": {
            "index_name": "sparse_vector_index", 
            "index_type": "SPARSE_INVERTED_INDEX", 
            "metric_type": "IP", 
            "params": {
                "inverted_index_algo": "DAAT_MAXSCORE"
            }
        }
    }
}
