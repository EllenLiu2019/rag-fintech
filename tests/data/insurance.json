{
    "name": "insurance",
    "version": "0.1",
    "fields": {
        "policy_number": {
            "position": "content",
            "match": {
                "strategy": "regex",
                "regex": "保险单号：([A-Z0-9]+)",
                "group": 1,
                "key_name": "保险单号"
            }
        },
        "policy_holder": {
            "position": "table",
            "match": {
                "strategy": "exact",   
                "values": ["投保人"],
                "target": 0
            }
        },
        "insured": {
            "position": "table",
            "match": {
                "strategy": "exact",
                "values": ["被保险人"],
                "target": 0
            }
        },
        "coverage": {
            "position": "table",
            "match": {
                "strategy": "exact",
                "values": ["保险名称"],
                "target": 0
            }
        },
        "cvg_premium": {
            "position": "table",
            "match": {
                "strategy": "exact",
                "values": ["条款名称"],
                "target": 0
            }
        },
        "effective_date": {
            "position": "content",
            "match": {
                "strategy": "regex",
                "regex": "(?:\\*\\*保险期间\\*\\*：|保险期间)[\\s\\S]*?自(\\d{4}年\\d{2}月\\d{2}日)[\\s\\S]*?起至",
                "group": 1,
                "key_name": "保险期间开始日期"
            }
        },
        "expiry_date": {
            "position": "content",
            "match": {
                "strategy": "regex",
                "regex": "(?:\\*\\*保险期间\\*\\*：|保险期间)[\\s\\S]*?自[\\s\\S]*?起至(\\d{4}年\\d{2}月\\d{2}日).*?止",
                "group": 1,
                "key_name": "保险期间结束日期"
            }
        }
    }
    
}